{
  "name": "wavefront",
  "version": "1.0.0",
  "description": "iOS/macOS Music Streaming App",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint": "swiftlint lint --strict",
    "lint:fix": "swiftlint lint --fix",
    "format": "swiftformat Sources Tests --swiftversion 5.9",
    "format:check": "swiftformat Sources Tests --lint --swiftversion 5.9",
    "test": "swift test",
    "test:ios": "xcodebuild test -scheme Wavefront -destination 'platform=iOS Simulator,name=iPhone 15' -quiet",
    "build": "swift build",
    "build:release": "swift build -c release",
    "clean": "swift package clean"
  },
  "devDependencies": {
    "husky": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
